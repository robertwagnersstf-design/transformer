{
    "name": "C++ Transformer Environment",
    "image": "mcr.microsoft.com/devcontainers/cpp:ubuntu-24.04",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    },
    "remoteUser": "root",
    "runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined"],
    "postCreateCommand": "apt-get update && apt-get install -y libomp-dev"
}